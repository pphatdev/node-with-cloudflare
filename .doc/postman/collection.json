									"    pm.collectionVariables.set('token', res.data.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/v1/api/auth/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["v1", "api", "auth", "refresh"]
						}
